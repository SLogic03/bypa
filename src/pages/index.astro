---
import Layout from '../layouts/Layout.astro';
import siteData from '../data/site-data.json';

const { hero, cita, stats, servicios, pilares, about, ctaBanner, contacto, footer, whatsappWidget } = siteData;
const waLink = `https://wa.me/${contacto.whatsapp.numero}?text=${contacto.whatsapp.mensaje}`;
---

<Layout
    title="Byron Altamirano | Psicólogo Clínico & Estratega Digital"
    description="Byron Altamirano - Psicólogo clínico, estratega digital y creador de contenido. Mentorías en marca personal y entrenamiento asertivo."
>
    <!-- ========== SPLASH INTRO ========== -->
    <div class="splash" id="splash">
        <img src="/assets/img/logo.svg" alt="Byron Altamirano Logo" class="splash-logo">
    </div>

    <!-- ========== NAVBAR ========== -->
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <a href="#hero" class="nav-logo">
                <img src="/assets/img/logo.svg" alt="Byron Altamirano Logo" class="logo-img">
            </a>
            <ul class="nav-links" id="navLinks">
                <li><a href="#hero" class="nav-link active">Inicio</a></li>
                <li><a href="#stats" class="nav-link">Resultados</a></li>
                <li><a href="#servicios" class="nav-link">Servicios</a></li>
                <li><a href="#about" class="nav-link">Sobre Mí</a></li>
                <li><a href="#contacto" class="nav-link nav-cta">Conectemos</a></li>
            </ul>
            <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <!-- ========== HERO FULLSCREEN ========== -->
    <section class="hero hero-fullscreen" id="hero">
        <div class="hero-bg-image" style={`background-image: url('${hero.heroImage}');`}></div>
        <div class="hero-overlay"></div>
        <div class="hero-container hero-container-fullscreen">
            <div class="hero-content hero-content-centered" data-animate="fade-up">
                <h1 class="hero-title">
                    <span class="hero-name-line">{hero.nombre}</span>
                    <span class="hero-name-line accent">{hero.apellido}</span>
                </h1>
                <p class="hero-tagline">
                    <span class="hero-tagline-top">{hero.taglineTop}</span>
                    <span class="hero-tagline-bottom">{hero.taglineBottom}</span>
                </p>
            </div>
        </div>
        <div class="scroll-indicator">
            <div class="mouse">
                <div class="mouse-wheel"></div>
            </div>
        </div>
    </section>

    <!-- ========== CITAS / QUOTES ========== -->
    <section class="citas" id="citas">
        <div class="container">
            <div class="citas-content" data-animate="fade-up">
                <p class="cita-quote">"{cita.texto}"</p>
                <div class="cita-divider"></div>
                <p class="cita-author">{cita.autor}</p>
                <p class="cita-role">{cita.rol}</p>
            </div>
        </div>
    </section>

    <!-- ========== STATS SECTION ========== -->
    <section class="stats" id="stats">
        <div class="container">
            <div class="section-header" data-animate="fade-up">
                <span class="section-tag">{stats.sectionTag}</span>
                <h2 class="section-title light">{stats.sectionTitle}</h2>
                <p class="section-desc light">{stats.sectionDesc}</p>
            </div>
            <div class="stats-grid">
                {stats.items.map((stat, i) => (
                    <div class="stat-card" data-animate="fade-up" data-delay={(i + 1) * 100}>
                        <div class="stat-icon"><i class={stat.icon}></i></div>
                        <div class="stat-number" data-count={stat.count}>0</div>
                        <div class="stat-unit">{stat.unit}</div>
                        <p class="stat-label">{stat.label}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ========== SERVICIOS SECTION ========== -->
    <section class="servicios" id="servicios">
        <div class="container">
            <div class="section-header" data-animate="fade-up">
                <span class="section-tag dark">{servicios.sectionTag}</span>
                <h2 class="section-title">{servicios.sectionTitle} <span class="word-highlight">{servicios.sectionTitleHighlight}</span></h2>
            </div>
            <div class="servicios-grid">
                {servicios.items.map((servicio, i) => (
                    <div class="servicio-card" data-animate="fade-up" data-delay={(i + 1) * 100}>
                        <div class="servicio-header">
                            <div class="servicio-icon">
                                <i class={servicio.icon}></i>
                            </div>
                            <h3 class="servicio-name">{servicio.nombre}</h3>
                        </div>
                        <div class="servicio-body">
                            <ul class="servicio-features">
                                {servicio.features.map((feature) => (
                                    <li>
                                        <i class="fas fa-check-circle"></i>
                                        <span><strong>{feature.titulo}:</strong> {feature.texto}</span>
                                    </li>
                                ))}
                            </ul>
                            {servicio.nota && (
                                <p class="servicio-note">
                                    <i class="fas fa-info-circle"></i>
                                    {servicio.nota}
                                </p>
                            )}
                        </div>
                        <a href={servicio.ctaLink} target="_blank" rel="noopener" class="btn btn-service">
                            <i class="fab fa-whatsapp"></i>
                            <span>{servicio.ctaTexto}</span>
                        </a>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ========== PILARES ========== -->
    <section class="pilares" id="pilares">
        <div class="container">
            <div class="section-header" data-animate="fade-up">
                <span class="section-tag">{pilares.sectionTag}</span>
                <h2 class="section-title light">{pilares.sectionTitle} <span class="word-highlight">{pilares.sectionTitleHighlight}</span></h2>
                <p class="section-desc light">{pilares.sectionDesc}</p>
            </div>
            <div class="pilares-grid">
                {pilares.items.map((pilar, i) => (
                    <div class="pilar-card" data-animate="fade-up" data-delay={(i + 1) * 100}>
                        <div class="pilar-icon"><i class={pilar.icon}></i></div>
                        <h3 class="pilar-title">{pilar.titulo}</h3>
                        <p class="pilar-text">{pilar.texto}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ========== TESTIMONIOS / TRANSFORMACION ========== -->
    <section class="testimonios" id="testimonios">
        <div class="container">
            <div class="section-header" data-animate="fade-up">
                <span class="section-tag dark">Resultados Reales</span>
                <h2 class="section-title">Ellos ya están transformando su mensaje</h2>
            </div>
            <div class="video-carousel" data-animate="fade-up" data-delay="100">
                <button class="carousel-arrow carousel-prev" aria-label="Video anterior">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <div class="carousel-viewport">
                    <div class="carousel-track">
                        <div class="carousel-slide">
                            <video class="carousel-video" src="/assets/video/Bypa1.mp4" playsinline preload="metadata"></video>
                            <div class="video-overlay">
                                <button class="video-play-btn" aria-label="Reproducir video"><i class="fas fa-play"></i></button>
                            </div>
                        </div>
                        <div class="carousel-slide">
                            <video class="carousel-video" src="/assets/video/Bypa2.mp4" playsinline preload="metadata"></video>
                            <div class="video-overlay">
                                <button class="video-play-btn" aria-label="Reproducir video"><i class="fas fa-play"></i></button>
                            </div>
                        </div>
                        <div class="carousel-slide">
                            <video class="carousel-video" src="/assets/video/Bypa3.mp4" playsinline preload="metadata"></video>
                            <div class="video-overlay">
                                <button class="video-play-btn" aria-label="Reproducir video"><i class="fas fa-play"></i></button>
                            </div>
                        </div>
                        <div class="carousel-slide">
                            <video class="carousel-video" src="/assets/video/Bypa4.mp4" playsinline preload="metadata"></video>
                            <div class="video-overlay">
                                <button class="video-play-btn" aria-label="Reproducir video"><i class="fas fa-play"></i></button>
                            </div>
                        </div>
                        <div class="carousel-slide">
                            <video class="carousel-video" src="/assets/video/Bypa5.mp4" playsinline preload="metadata"></video>
                            <div class="video-overlay">
                                <button class="video-play-btn" aria-label="Reproducir video"><i class="fas fa-play"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
                <button class="carousel-arrow carousel-next" aria-label="Video siguiente">
                    <i class="fas fa-chevron-right"></i>
                </button>
                <div class="carousel-dots"></div>
            </div>
        </div>
    </section>

    <!-- ========== ABOUT SECTION ========== -->
    <section class="about" id="about">
        <div class="container">
            <div class="about-grid">
                <div class="about-image" data-animate="fade-right">
                    <div class="about-img-wrapper">
                        <img src={about.aboutImage} alt="Byron Altamirano - Sobre Mí" loading="lazy">
                    </div>
                    <div class="about-img-decoration"></div>
                </div>
                <div class="about-content" data-animate="fade-left">
                    <span class="section-tag">{about.sectionTag}</span>
                    <h2 class="section-title light">{about.sectionTitle}</h2>
                    {about.parrafos.map((parrafo) => (
                        <p class="about-text" set:html={parrafo} />
                    ))}
                    <p class="about-text highlight">
                        <em>{about.destacado}</em>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== CTA BANNER ========== -->
    <section class="cta-banner">
        <div class="container">
            <div class="cta-banner-content" data-animate="fade-up">
                <h2 class="cta-banner-title">{ctaBanner.titulo}</h2>
                <p class="cta-banner-text">{ctaBanner.texto}</p>
                <a href="#contacto" class="btn-white">
                    <i class="fas fa-rocket"></i>
                    <span>Empieza Ahora</span>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== CONTACTO SECTION ========== -->
    <section class="contacto" id="contacto">
        <div class="contacto-bg-shapes">
            <div class="shape shape-4"></div>
            <div class="shape shape-5"></div>
        </div>
        <div class="container">
            <div class="contacto-content" data-animate="fade-up">
                <span class="section-tag">{contacto.sectionTag}</span>
                <h2 class="cta-title">{contacto.sectionTitle}</h2>

                <div class="contacto-actions">
                    <a href={waLink} target="_blank" rel="noopener" class="contact-card whatsapp">
                        <div class="contact-icon"><i class="fab fa-whatsapp"></i></div>
                        <div class="contact-info">
                            <span class="contact-label">WhatsApp</span>
                            <span class="contact-value">Da el primer paso aquí</span>
                        </div>
                        <i class="fas fa-arrow-right"></i>
                    </a>
                    <a href={`mailto:${contacto.email}`} class="contact-card email">
                        <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                        <div class="contact-info">
                            <span class="contact-label">Email</span>
                            <span class="contact-value">{contacto.email}</span>
                        </div>
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>

                <div class="contacto-social">
                    <a href={contacto.instagram} target="_blank" rel="noopener" class="social-link">
                        <i class="fab fa-instagram"></i>
                        <span>{contacto.instagramUser}</span>
                    </a>
                    <a href={contacto.tiktok} target="_blank" rel="noopener" class="social-link">
                        <i class="fab fa-tiktok"></i>
                        <span>{contacto.tiktokUser}</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== ENHANCED FOOTER ========== -->
    <footer class="footer-enhanced">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <a href="#hero" class="nav-logo">
                        <img src="/assets/img/logo.svg" alt="Byron Altamirano Logo" class="logo-img" style="height:60px;">
                    </a>
                    <p>{footer.brandText}</p>
                </div>
                <div class="footer-col">
                    <h4>Links Rápidos</h4>
                    <ul>
                        <li><a href="#hero"><i class="fas fa-chevron-right"></i> Inicio</a></li>
                        <li><a href="#stats"><i class="fas fa-chevron-right"></i> Resultados</a></li>
                        <li><a href="#servicios"><i class="fas fa-chevron-right"></i> Servicios</a></li>
                        <li><a href="#about"><i class="fas fa-chevron-right"></i> Sobre Mí</a></li>
                        <li><a href="#contacto"><i class="fas fa-chevron-right"></i> Contacto</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Redes Sociales</h4>
                    <ul>
                        <li><a href={contacto.instagram} target="_blank" rel="noopener"><i class="fab fa-instagram"></i> Instagram</a></li>
                        <li><a href={contacto.tiktok} target="_blank" rel="noopener"><i class="fab fa-tiktok"></i> TikTok</a></li>
                        <li><a href={`https://wa.me/${contacto.whatsapp.numero}`} target="_blank" rel="noopener"><i class="fab fa-whatsapp"></i> WhatsApp</a></li>
                        <li><a href={`mailto:${contacto.email}`}><i class="fas fa-envelope"></i> Email</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p class="footer-bottom-text">{footer.copyright}</p>
            </div>
        </div>
    </footer>

    <!-- ========== WHATSAPP CHATBOX WIDGET ========== -->
    <div class="wa-widget" id="waWidget">
        <button class="wa-fab" id="waFab" aria-label="Abrir chat de WhatsApp">
            <i class="fab fa-whatsapp wa-fab-icon-open"></i>
            <i class="fas fa-times wa-fab-icon-close"></i>
        </button>

        <div class="wa-chatbox" id="waChatbox">
            <div class="wa-chatbox-header">
                <div class="wa-chatbox-avatar">
                    <i class="fas fa-headset"></i>
                </div>
                <div class="wa-chatbox-info">
                    <span class="wa-chatbox-name">{whatsappWidget.nombre}</span>
                    <span class="wa-chatbox-role">{whatsappWidget.rol}</span>
                </div>
                <button class="wa-chatbox-close" id="waChatboxClose" aria-label="Cerrar chat">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="wa-chatbox-body">
                <div class="wa-msg-bubble">
                    <p set:html={whatsappWidget.mensajeBienvenida} />
                    <span class="wa-msg-time">Justo ahora</span>
                </div>

                <div class="wa-quick-options">
                    <p class="wa-quick-label">Elige una opción:</p>
                    {whatsappWidget.opciones.map((opcion) => (
                        <button class="wa-quick-btn" data-msg={opcion.msg}>
                            <i class={opcion.icon}></i> {opcion.texto}
                        </button>
                    ))}
                </div>

                <div class="wa-custom-msg">
                    <textarea class="wa-textarea" id="waTextarea" placeholder="O escribe tu mensaje personalizado..."
                        rows="3"></textarea>
                </div>
            </div>

            <div class="wa-chatbox-footer">
                <button class="wa-send-btn" id="waSendBtn">
                    <i class="fab fa-whatsapp"></i>
                    <span>Chatear por WhatsApp</span>
                </button>
            </div>
        </div>
    </div>
</Layout>
